<file path="prisma/schema.prisma">
// 1. Generator remains the same
generator client {
  provider = "prisma-client-js"
}

// 2. Data Source: We REMOVE the 'url' line here per Prisma 7 rules
datasource db {
  provider = "postgresql"
}

// 3. The Role Hierarchy
enum Role {
  SUPERADMIN
  ADMIN
  MODERATOR
  USER
  INTERN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?   // <-- UPDATED: Now optional for OAuth
  role          Role      @default(USER)
  isActive      Boolean   @default(true)

  // Required by Auth.js Prisma adapter
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Domain relations
  createdSecrets Secret[] @relation("SecretOwner")
  createdNotes   Note[]   @relation("NoteOwner")
  sharedSecrets  Secret[] @relation("SecretAccess")
  sharedNotes    Note[]   @relation("NoteAccess")

  createdProjects Project[] @relation("ProjectCreator")
  updatedProjects Project[] @relation("ProjectUpdater")
  ownedProjects   Project[] @relation("ProjectOwner")
  updatedNotes    Note[]    @relation("NoteUpdater")

  credentialSectionsOwned   CredentialSection[] @relation("CredentialSectionOwner")
  credentialSectionsUpdated CredentialSection[] @relation("CredentialSectionUpdater")
  credentialKeysOwned       CredentialKey[]     @relation("CredentialKeyOwner")
  credentialKeysUpdated     CredentialKey[]     @relation("CredentialKeyUpdater")
  sharedCredentialSections  CredentialSection[] @relation("CredentialSectionAccess")

  /** Explicit project membership (ADMIN/SUPERADMIN assignments on User Management). */
  projectMembers ProjectMember[]

  activityLogs ActivityLog[]

  /** Invitations sent by this admin/superadmin. */
  sentInvitations UserInvitation[] @relation("InvitationSender")

  pendingSecretSubmissionsSubmitted PendingSecretSubmission[] @relation("PendingSecretSubmitter")
  pendingSecretSubmissionsReviewed  PendingSecretSubmission[] @relation("PendingSecretReviewer")
  pendingNoteSubmissionsSubmitted   PendingNoteSubmission[]   @relation("PendingNoteSubmitter")
  pendingNoteSubmissionsReviewed    PendingNoteSubmission[]   @relation("PendingNoteReviewer")
  pendingCredentialKeySubmissionsSubmitted PendingCredentialKeySubmission[] @relation("PendingCredentialKeySubmitter")
  pendingCredentialKeySubmissionsReviewed  PendingCredentialKeySubmission[] @relation("PendingCredentialKeyReviewer")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

/** Email invite created by ADMIN/SUPERADMIN; user completes signup via token link. */
model UserInvitation {
  id          String    @id @default(cuid())
  token       String    @unique
  email       String
  role        Role
  invitedById String
  invitedBy   User      @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([email])
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  ARCHIVE
  ASSIGN
  REMOVE
  LEAVE
  STATUS
}

/** Audit trail for vault / admin mutations (visible on Activity page). */
model ActivityLog {
  id         String         @id @default(cuid())
  createdAt  DateTime       @default(now())
  actorId    String
  actor      User           @relation(fields: [actorId], references: [id], onDelete: Cascade)
  action     ActivityAction
  entityType String
  entityId   String?
  label      String?        @db.Text

  @@index([createdAt])
  @@index([entityType, entityId])
}

// ---------------------------------------------------------------------------
// Auth.js adapter models
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  /** When set, this project is a subproject of another project. */
  parentId    String?
  parent      Project?  @relation("ProjectHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Project[] @relation("ProjectHierarchy")

  secrets     Secret[]
  notes       Note[]
  members     ProjectMember[]
  status      VaultEntityStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  createdById String?
  createdBy   User?    @relation("ProjectCreator", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?    @relation("ProjectUpdater", fields: [updatedById], references: [id])

  ownerId     String?
  owner       User?    @relation("ProjectOwner", fields: [ownerId], references: [id])

  pendingSecretSubmissions PendingSecretSubmission[]
  pendingNoteSubmissions   PendingNoteSubmission[]

  @@index([parentId])
  @@index([status])
  @@index([createdById])
  @@index([updatedById])
  @@index([ownerId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

model Secret {
  id             String   @id @default(cuid())
  key            String   // e.g., "DATABASE_URL"
  encryptedValue String   // AES-256-GCM ciphertext + auth tag (hex)
  iv             String   // AES-256-GCM 96-bit initialisation vector (hex)
  environment    String   @default("Default") // e.g., "local", "development", "production"

  // Project relation
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Ownership
  ownerId        String
  owner          User     @relation("SecretOwner", fields: [ownerId], references: [id])

  // allowedUserIds — the explicit per-user access list.
  // A record is visible to a USER/INTERN ONLY if their id appears here.
  // MODERATOR and above bypass this list via role-based access.
  // Stored as a relation (not String[]) so referential integrity is enforced.
  sharedWith     User[]   @relation("SecretAccess")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum NoteType {
  NORMAL
  PROJECT_BASED
}

enum VaultEntityStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model Note {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  type        NoteType @default(NORMAL)

  // Optional project relation (only set when type = PROJECT_BASED)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Ownership
  ownerId     String
  owner       User     @relation("NoteOwner", fields: [ownerId], references: [id])

  updatedById String?
  updatedBy   User?    @relation("NoteUpdater", fields: [updatedById], references: [id])

  // allowedUserIds — the explicit per-user access list.
  // A record is visible to a USER/INTERN ONLY if their id appears here.
  // MODERATOR and above bypass this list via role-based access.
  // Stored as a relation (not String[]) so referential integrity is enforced.
  sharedWith  User[]   @relation("NoteAccess")

  status      VaultEntityStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /** Optional back-reference for USER edits that await admin approval. */
  pendingEditSubmissions PendingNoteSubmission[] @relation("PendingNoteOriginal")

  @@index([status])
}

model CredentialSection {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  status      VaultEntityStatus @default(ACTIVE)

  ownerId     String
  owner       User     @relation("CredentialSectionOwner", fields: [ownerId], references: [id])

  updatedById String?
  updatedBy   User?    @relation("CredentialSectionUpdater", fields: [updatedById], references: [id])

  keys        CredentialKey[]

  sharedWith  User[]   @relation("CredentialSectionAccess")

  pendingCredentialKeySubmissions PendingCredentialKeySubmission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([ownerId])
  @@index([updatedById])
}

/** USER-submitted credential key awaiting ADMIN/SUPERADMIN approval. */
model PendingCredentialKeySubmission {
  id             String                  @id @default(cuid())
  createdAt      DateTime                @default(now())
  status         PendingSubmissionStatus @default(PENDING)
  submitterId    String
  submitter      User                    @relation("PendingCredentialKeySubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  sectionId      String
  section        CredentialSection       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  label          String
  value          String                  @db.Text
  reviewedById   String?
  reviewer       User?                   @relation("PendingCredentialKeyReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?
  rejectionNote  String?                 @db.Text

  @@index([status])
  @@index([submitterId])
  @@index([sectionId])
}

model CredentialKey {
  id          String   @id @default(cuid())
  sectionId   String
  section     CredentialSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  label       String
  value       String   @db.Text

  ownerId     String
  owner       User     @relation("CredentialKeyOwner", fields: [ownerId], references: [id])

  updatedById String?
  updatedBy   User?    @relation("CredentialKeyUpdater", fields: [updatedById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sectionId])
  @@index([ownerId])
  @@index([updatedById])
}

enum PendingSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

/** USER-submitted secret awaiting ADMIN/SUPERADMIN approval (not live until approved). */
model PendingSecretSubmission {
  id             String                  @id @default(cuid())
  createdAt      DateTime                @default(now())
  status         PendingSubmissionStatus @default(PENDING)
  environment    String                  @default("Default")
  submitterId    String
  submitter      User                    @relation("PendingSecretSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key            String
  encryptedValue String
  iv             String
  reviewedById   String?
  reviewer       User?                   @relation("PendingSecretReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?
  rejectionNote  String?                 @db.Text

  @@index([status])
  @@index([submitterId])
}

/** USER-submitted note awaiting ADMIN/SUPERADMIN approval. */
model PendingNoteSubmission {
  id             String                  @id @default(cuid())
  createdAt      DateTime                @default(now())
  status         PendingSubmissionStatus @default(PENDING)
  submitterId    String
  submitter      User                    @relation("PendingNoteSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  title          String
  content        String                  @db.Text
  type           NoteType
  projectId      String?
  project        Project?                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewedById   String?
  reviewer       User?                   @relation("PendingNoteReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?
  rejectionNote  String?                 @db.Text

  /// When set, this represents an edit to an existing note rather than a brand new note.
  originalNoteId String?
  originalNote   Note?                   @relation("PendingNoteOriginal", fields: [originalNoteId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([submitterId])
}
