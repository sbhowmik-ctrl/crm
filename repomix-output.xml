                                          <Plus className={`size-2.5 text-blue-500 transition-opacity ${false ? "opacity-100" : "opacity-0"}`} />
                                      </div>
                                      <input
                                        type="checkbox"
                                        className="sr-only"
                                        disabled={isPending}
                                        onChange={(e) => selectAllLoadedSubs(root.id, e.target.checked)}
