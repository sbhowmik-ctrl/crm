                      </div>
                    </div>

                    {note.sharedWith.length > 0 && (
                      <>
                        <div className="w-px h-8 bg-white/20" />
                        <div className="flex flex-col gap-1">
                          <span className="text-[9px] font-black text-slate-400 uppercase tracking-widest">
